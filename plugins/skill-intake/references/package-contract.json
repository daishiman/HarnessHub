{
  "$schema": "../../harness-creator/skills/ref-pkg-contract/schemas/package-contract.schema.json",
  "package_mode": "bundle",
  "plugin_name": "skill-intake",
  "entry_points": {
    "skills": [
      "run-skill-intake",
      "run-intake-kickoff",
      "run-intake-interview",
      "run-intake-option-catalog",
      "run-intake-visualize",
      "run-intake-finalize",
      "run-notion-intake-publish",
      "assign-notion-fidelity-evaluator",
      "run-intake-next-action",
      "run-intake-revise"
    ],
    "agents": [
      "skill-intake-assumption-challenger",
      "skill-intake-purpose-excavator",
      "skill-intake-summarizer",
      "skill-intake-user-profiler"
    ],
    "commands": ["intake", "intake-publish", "intake-revise", "intake-status"],
    "hooks": [
      "hook-guard-skillgen.py",
      "pre-publish-secret-scrub.sh",
      "pre-publish-schema-validate.py",
      "post-publish-notify.sh",
      "post-keychain-add.sh"
    ]
  },
  "distribution": {
    "distributable": true,
    "bundle_targets": ["skills-full", "skills-intake"],
    "category": "requirements-intake",
    "tags": ["intake", "notion", "non-engineer-elicitation"]
  },
  "depends_on": [],
  "pkg_checks": {}
}
