{
  "description": "Protect confirmed system-spec chapters and the canonical spec state from unsafe mutation, and record audit sub-agent forks as tamper-independent evidence.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-confirmed-chapter-overwrite.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/record-audit-fork.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
