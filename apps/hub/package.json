{
  "name": "@harness-hub/hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hub 本体 (Next.js on Cloudflare Workers)。UI + API + 認可 MW の単一 deploy unit",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:next": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare deploy",
    "test": "vitest run",
    "test:a11y": "vitest run tests/a11y",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm --workspace-root exec biome check apps/hub",
    "check:bundle": "node scripts/check-bundle.mjs"
  },
  "dependencies": {
    "@harness-hub/db": "workspace:*",
    "@harness-hub/estimation": "workspace:*",
    "@harness-hub/inspection": "workspace:*",
    "@harness-hub/schemas": "workspace:*",
    "@harness-hub/ui": "workspace:*",
    "next": "^15.5.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "axe-core": "^4.10.2",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
