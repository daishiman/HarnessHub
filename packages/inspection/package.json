{
  "name": "@harness-hub/inspection",
  "version": "0.1.0",
  "private": true,
  "description": "検査 pipeline 共有 package (純関数)。Hub 正式検査と Publisher ローカル pre-check が同一実装を参照する",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "files": [
    "src",
    "scan",
    "scripts"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm --workspace-root exec biome check packages/inspection",
    "scan:secrets": "node ./scripts/scan-secrets.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
