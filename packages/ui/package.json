{
  "name": "@harness-hub/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "共通 UI (design system)。docs/shared-layers.md §1 の正本。ビルドせず src を直接公開し、apps 側が transpilePackages で取込む",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:a11y": "vitest run src/a11y",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
